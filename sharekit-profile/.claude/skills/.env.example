# Machine-specific values the (now generic) skills resolve against.
# Set these in ~/.claude/settings.local.json under "env": { ... }, or export them in your shell.
# settings.local.json is per-machine and not shared — that's where YOUR values live.

# --- required ---
DEV_ROOT="$HOME/projects"          # your active dev root (skills reference ${DEV_ROOT})
EXTERNAL_HD="$HOME"                # external/secondary storage root, or just $HOME
GITHUB_USER="your-username"        # your GitHub handle (${GITHUB_USER})
OPERATOR_EMAIL="you@example.com"   # identity/commit contexts (${OPERATOR_EMAIL})

# --- optional: only if you use these integrations (the "personal-stack" skills) ---
BRAIN_ROOT="$DEV_ROOT/knowledge-brain"   # RAG / memory vault
HOMELAB_HOST=""                          # homelab host or IP
TAILSCALE_IP=""
AGENT_BOX_HOST=""

# --- secrets: referenced as ${VAR} in settings.json / .mcp.json ---
# Set the real values in your shell env or a secrets manager. NEVER commit them.
# NEON_API_KEY  NOTION_API_KEY  FIRECRAWL_API_KEY  SONARQUBE_TOKEN  TAVILY_API_KEY
