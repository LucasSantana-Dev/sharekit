{
  "name": "@lucassantana/sharekit",
  "version": "0.2.0",
  "description": "Share your AI coding setup with anyone — one command to install, one to rollback.",
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "copilot",
    "dotfiles",
    "cli",
    "config"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "sharekit": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucasSantana-Dev/sharekit.git"
  }
}
